{
  "include": ["./src/**/*.ts"],
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "dist",
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "declaration": false,
    "skipLibCheck": true,
    "strict": true,
    "removeComments": false,
    "noEmitOnError": true
  }
}
